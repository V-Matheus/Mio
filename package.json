{
  "name": "mio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:cov": "turbo run test:cov",
    "test:ui": "vitest --ui --coverage",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.10",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/api/**/*.{ts,tsx}": [
      "biome check --fix",
      "bash -c 'yarn check-types --filter=@mio/api'",
      "bash -c 'yarn test:unit --filter=@mio/api'"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "biome check --fix",
      "bash -c 'yarn check-types --filter=@mio/web'",
      "bash -c 'yarn test:unit --filter=@mio/web'"
    ]
  }
}
