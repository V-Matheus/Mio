{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "every weekend"
  ],
  "timezone": "America/Sao_Paulo",
  "packageRules": [
    {
      "description": "Auto-merge patch updates when CI passes",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Group NestJS packages together",
      "groupName": "nestjs",
      "matchPackageNames": [
        "/^@nestjs//"
      ]
    },
    {
      "description": "Group testing packages together",
      "groupName": "testing",
      "matchPackageNames": [
        "/^@vitest//",
        "/^vitest$/",
        "/^supertest$/",
        "/^@types/supertest$/"
      ]
    },
    {
      "description": "Group React packages together",
      "groupName": "react",
      "matchPackageNames": [
        "/^react/",
        "/^@types/react/"
      ]
    },
    {
      "description": "Group Tailwind and PostCSS together",
      "groupName": "tailwind",
      "matchPackageNames": [
        "/^tailwindcss$/",
        "/^@tailwindcss//",
        "/^postcss$/"
      ]
    },
    {
      "description": "Group Biome packages together",
      "groupName": "biome",
      "matchPackageNames": [
        "/^@biomejs//"
      ]
    },
    {
      "description": "Group TypeScript and type definitions together",
      "groupName": "typescript",
      "matchPackageNames": [
        "/^typescript$/",
        "/^@types/node$/"
      ]
    }
  ]
}
