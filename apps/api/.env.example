NODE_ENV=development

# Postgres
POSTGRES_USER=mio
POSTGRES_PASSWORD=mio
POSTGRES_DB=mio
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Service ports
GATEWAY_PORT=3333
CORE_PORT=3001
GAMIFICATION_PORT=3002
ACHIEVEMENTS_PORT=3003
MESSENGER_PORT=3334
NOTIFICATIONS_PORT=3004

# Service connections (hostnames match docker-compose service names)
DATABASE_URL=postgresql://mio:mio@postgres:5432/mio
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://rabbitmq:5672
