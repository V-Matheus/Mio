NODE_ENV=development

# Postgres
CORE_DATABASE_URL=postgresql://${CORE_POSTGRES_USER}:${CORE_POSTGRES_PASSWORD}@postgres-core:5432/${CORE_POSTGRES_DB}
GAMIFICATION_DATABASE_URL=postgresql://${GAMIFICATION_POSTGRES_USER}:${GAMIFICATION_POSTGRES_PASSWORD}@postgres-gamification:5432/${GAMIFICATION_POSTGRES_DB}
ACHIEVEMENTS_DATABASE_URL=postgresql://${ACHIEVEMENTS_POSTGRES_USER}:${ACHIEVEMENTS_POSTGRES_PASSWORD}@postgres-achievements:5432/${ACHIEVEMENTS_POSTGRES_DB}
POSTGRES_USER=mio
POSTGRES_PASSWORD=mio
POSTGRES_DB=mio
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Service ports
GATEWAY_PORT=3333

# gRPC service ports
CORE_GRPC_PORT=5001
GAMIFICATION_GRPC_PORT=5002
ACHIEVEMENTS_GRPC_PORT=5003
MESSENGER_GRPC_PORT=5004
NOTIFICATIONS_GRPC_PORT=5005

# Service connections (hostnames match docker-compose service names)
DATABASE_URL=postgresql://mio:mio@postgres:5432/mio
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://rabbitmq:5672

# Core service database
CORE_POSTGRES_USER=mio
CORE_POSTGRES_PASSWORD=mio
CORE_POSTGRES_DB=core
CORE_POSTGRES_PORT=5432

# Gamification service database
GAMIFICATION_POSTGRES_USER=mio
GAMIFICATION_POSTGRES_PASSWORD=mio
GAMIFICATION_POSTGRES_DB=gamification
GAMIFICATION_POSTGRES_PORT=5433

# Achievements service database
ACHIEVEMENTS_POSTGRES_USER=mio
ACHIEVEMENTS_POSTGRES_PASSWORD=mio
ACHIEVEMENTS_POSTGRES_DB=achievements
ACHIEVEMENTS_POSTGRES_PORT=5434