{
  "name": "@mio/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "yarn prisma:generate",
    "dev": "docker compose -f docker-compose.yml up",
    "dev:build": "docker compose -f docker-compose.yml up --build",
    "dev:gateway": "nest start gateway --watch",
    "dev:core": "nest start core --watch",
    "dev:gamification": "nest start gamification --watch",
    "dev:achievements": "nest start achievements --watch",
    "dev:messenger": "nest start messenger --watch",
    "dev:notifications": "nest start notifications --watch",
    "build": "nest build gateway && nest build core && nest build gamification && nest build achievements && nest build messenger && nest build notifications",
    "build:gateway": "nest build gateway",
    "build:core": "nest build core",
    "build:gamification": "nest build gamification",
    "build:achievements": "nest build achievements",
    "build:messenger": "nest build messenger",
    "build:notifications": "nest build notifications",
    "start:gateway": "node dist/apps/gateway/main",
    "start:core": "node dist/apps/core/main",
    "start:gamification": "node dist/apps/gamification/main",
    "start:achievements": "node dist/apps/achievements/main",
    "start:messenger": "node dist/apps/messenger/main",
    "start:notifications": "node dist/apps/notifications/main",
    "prisma:generate": "for s in core gamification achievements; do prisma generate --schema=apps/$s/prisma/schema.prisma || exit 1; done",
    "prisma:migrate:dev": "for s in core gamification achievements; do prisma migrate dev --schema=apps/$s/prisma/schema.prisma || exit 1; done",
    "prisma:migrate:deploy": "for s in core gamification achievements; do prisma migrate deploy --schema=apps/$s/prisma/schema.prisma || exit 1; done",
    "prisma:studio:core": "dotenv -e .env -- sh -c 'CORE_DATABASE_URL=postgresql://$CORE_POSTGRES_USER:$CORE_POSTGRES_PASSWORD@localhost:$CORE_POSTGRES_PORT/$CORE_POSTGRES_DB prisma studio --schema=apps/core/prisma/schema.prisma --port 5555'",
    "prisma:studio:gamification": "dotenv -e .env -- sh -c 'GAMIFICATION_DATABASE_URL=postgresql://$GAMIFICATION_POSTGRES_USER:$GAMIFICATION_POSTGRES_PASSWORD@localhost:$GAMIFICATION_POSTGRES_PORT/$GAMIFICATION_POSTGRES_DB prisma studio --schema=apps/gamification/prisma/schema.prisma --port 5556'",
    "prisma:studio:achievements": "dotenv -e .env -- sh -c 'ACHIEVEMENTS_DATABASE_URL=postgresql://$ACHIEVEMENTS_POSTGRES_USER:$ACHIEVEMENTS_POSTGRES_PASSWORD@localhost:$ACHIEVEMENTS_POSTGRES_PORT/$ACHIEVEMENTS_POSTGRES_DB prisma studio --schema=apps/achievements/prisma/schema.prisma --port 5557'",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.2.0",
    "@grpc/grpc-js": "^1.12.2",
    "nanoid": "^5.0.9",
    "@grpc/proto-loader": "^0.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@mio/testing-config": "*",
    "@mio/typescript-config": "*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0"
  }
}
