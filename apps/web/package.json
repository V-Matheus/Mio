{
  "name": "@mio/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "predev": "yarn codegen",
    "dev": "next dev --port 3000",
    "docker:dev": "trap 'docker compose -p mio-dev -f ../../docker-compose.dev.yml down' EXIT INT TERM; docker compose -p mio-dev -f ../../docker-compose.dev.yml up --build --no-deps web",
    "prebuild": "yarn codegen",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "precheck-types": "yarn codegen",
    "check-types": "next typegen && tsc --noEmit",
    "pretest": "yarn codegen",
    "test": "vitest run",
    "pretest:unit": "yarn codegen",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "pretest:e2e": "yarn codegen",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "pretest:cov": "yarn codegen",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@tailwindcss/postcss": "^4.2.0",
    "graphql": "^17.0.0",
    "graphql-request": "^7.4.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@iconify-icons/devicon": "^1.2.17",
    "@iconify-icons/logos": "^1.2.36",
    "@iconify-icons/lucide": "^1.2.135",
    "@iconify-icons/mdi": "^1.2.48",
    "@mio/graphql-schema": "*",
    "@mio/testing-config": "*",
    "@mio/typescript-config": "*",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "storybook": "^10.2.16",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
